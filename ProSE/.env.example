# Copy this file to ".env" and fill in your Gmail App Password.
# The App Password is a 16-character code generated at
# https://myaccount.google.com/apppasswords (requires 2-Step Verification).
#
# The SENDER address and recipients are configured in the dashboard / config.json;
# only the secret password lives here.

PROSE_SMTP_PASSWORD=your-16-char-app-password-here
